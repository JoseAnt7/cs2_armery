# MySQL (contenedor skinatlas-mysql)
MYSQL_DATABASE=skinatlas
MYSQL_USER=skinatlas
MYSQL_PASSWORD=change_mysql_password
MYSQL_ROOT_PASSWORD=change_root_password

# Puerto HTTP en el VPS (8081 para no chocar con VibeUp/Agentes en :80)
HTTP_PORT=8081

# Dejar vacío: el frontend usa /api y Nginx hace proxy al backend
VITE_API_BASE=

# Dominio público (Traefik / Let's Encrypt)
TRAEFIK_DOMAIN=skinatlas.es
