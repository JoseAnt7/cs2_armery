# Flask
JWT_SECRET_KEY=change_this_super_secret
PORT=5000
FLASK_DEBUG=false

# MySQL (contenedor docker-compose). Debe coincidir con .env de la raíz (MYSQL_*)
DATABASE_URL=mysql+pymysql://skinatlas:change_mysql_password@mysql:3306/skinatlas

# Primer admin (opcional): POST /api/admin/bootstrap con cabecera X-Admin-Bootstrap-Token
ADMIN_BOOTSTRAP_TOKEN=

# Refresco automático de cachés (1=activo)
ENABLE_SCHEDULER=1
ENABLE_CACHE_WARMUP=1
SCHEDULER_TZ=Europe/Madrid
CATALOG_REFRESH_HOUR=4
PRICE_INDEX_REFRESH_HOURS=4
